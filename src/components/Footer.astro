---
const footerLinks = [
  { label: "Inicio", link: "#home" },
  { label: "Experiencia", link: "#experience" },
  { label: "Proyectos", link: "#projects" },
  { label: "Sobre mí", link: "#about" },
  { label: "Contacto", link: "#contact" },
];
---

<footer class="pb-10 pt-2">
  <div class="container-shell">
    <div class="surface flex flex-col gap-6 px-6 py-6 md:flex-row md:items-end md:justify-between md:px-8">
      <div class="space-y-2">
        <p class="text-sm font-semibold uppercase tracking-[0.18em] text-[var(--accent-strong)]">
          Sergio Lamorda
        </p>
        <p class="max-w-xl text-sm leading-6 text-[var(--muted)]">
          Portfolio enfocado en producto digital, ingeniería frontend sólida y una evolución clara hacia automatización e IA aplicada.
        </p>
      </div>

      <div class="flex flex-col gap-4 md:items-end">
        <nav class="flex flex-wrap gap-3 text-sm text-[var(--muted)] md:justify-end">
          {
            footerLinks.map(({ label, link }) => (
              <a href={link} class="rounded-full border border-[var(--line)] bg-white/60 px-3 py-2 transition hover:border-[var(--accent)] hover:text-[var(--accent)]">
                {label}
              </a>
            ))
          }
        </nav>
        <p class="text-sm text-[var(--muted)]">
          © {new Date().getFullYear()} · Diseñado y desarrollado por Sergio Lamorda.
        </p>
      </div>
    </div>
  </div>
</footer>
