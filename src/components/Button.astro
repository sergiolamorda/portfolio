---
const {
  href,
  target,
  rel,
  variant = "primary",
  class: className = "",
  type = "button",
  ...props
} = Astro.props;

const Tag = href ? "a" : "button";

const variants = {
  primary:
    "border-transparent bg-[var(--text)] text-white hover:-translate-y-0.5 hover:bg-[#1d3250] hover:shadow-[0_18px_35px_rgba(18,32,51,0.18)]",
  secondary:
    "border-[var(--line)] bg-[var(--surface-strong)] text-[var(--text)] hover:-translate-y-0.5 hover:border-[var(--accent)] hover:text-[var(--accent)]",
  subtle:
    "border-transparent bg-[var(--accent-soft)] text-[var(--accent-strong)] hover:-translate-y-0.5 hover:bg-[rgba(15,159,148,0.22)]",
};
---

<Tag
  {...props}
  href={href}
  target={target}
  rel={rel}
  type={href ? undefined : type}
  class:list={[
    "inline-flex items-center justify-center gap-2 rounded-full border px-5 py-3 text-sm font-semibold tracking-tight transition duration-300 focus:outline-none focus:ring-4 focus:ring-[rgba(15,159,148,0.18)]",
    variants[variant] ?? variants.primary,
    className,
  ]}
>
  <slot />
</Tag>
