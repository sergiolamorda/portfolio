---
import BaseLayout from "../layouts/BaseLayout.astro";
import Button from "../components/Button.astro";

import AmazonWebServicesIcon from "../icons/AmazonWebServices.astro";
import AstroIcon from "../icons/Astro.astro";
import CodeIgniterIcon from "../icons/CodeIgniter.astro";
import DockerIcon from "../icons/Docker.astro";
import ExpressIcon from "../icons/Express.astro";
import GithubIcon from "../icons/Github.astro";
import GmailIcon from "../icons/Gmail.astro";
import LaravelIcon from "../icons/Laravel.astro";
import LinkedinIcon from "../icons/Linkedin.astro";
import MongoIcon from "../icons/Mongo.astro";
import MysqlIcon from "../icons/Mysql.astro";
import NextIcon from "../icons/Next.astro";
import NodeIcon from "../icons/Node.astro";
import PHPIcon from "../icons/PHP.astro";
import ReactIcon from "../icons/React.astro";
import RedisIcon from "../icons/Redis.astro";
import SocketsIcon from "../icons/Socketsio.astro";
import StripeIcon from "../icons/Stripe.astro";
import SvelteIcon from "../icons/Svelte.astro";
import TailwindIcon from "../icons/Tailwind.astro";
import ThreejsIcon from "../icons/Threejs.astro";
import VueIcon from "../icons/Vue.astro";
import WorldIcon from "../icons/World.astro";

const TECHNOLOGIES = {
  vue: { name: "Vue", icon: VueIcon },
  next: { name: "Next.js", icon: NextIcon },
  astro: { name: "Astro", icon: AstroIcon },
  mongo: { name: "MongoDB", icon: MongoIcon },
  node: { name: "Node.js", icon: NodeIcon },
  docker: { name: "Docker", icon: DockerIcon },
  svelte: { name: "Svelte", icon: SvelteIcon },
  react: { name: "React", icon: ReactIcon },
  tailwind: { name: "Tailwind", icon: TailwindIcon },
  aws: { name: "AWS", icon: AmazonWebServicesIcon },
  redis: { name: "Redis", icon: RedisIcon },
  php: { name: "PHP", icon: PHPIcon },
  laravel: { name: "Laravel", icon: LaravelIcon },
  mysql: { name: "MySQL", icon: MysqlIcon },
  codeigniter: { name: "CodeIgniter", icon: CodeIgniterIcon },
  express: { name: "Express", icon: ExpressIcon },
  stripe: { name: "Stripe", icon: StripeIcon },
  three: { name: "Three.js", icon: ThreejsIcon },
  sockets: { name: "Sockets.io", icon: SocketsIcon },
};

const HERO_TAGS = [
  "Frontend",
  "Producto",
  "SaaS",
  "Performance",
  "Automation",
  "IA con criterio",
];

const METRICS = [
  { value: "+7", label: "años trabajando en producto digital" },
  { value: "1", label: "SaaS propio llevado a producción" },
  { value: "BCN", label: "Barcelona como base" },
  { value: "E2E", label: "capaz de moverme por todo el stack" },
];

const FOCUS_AREAS = [
  {
    title: "Frontend que se entiende",
    description:
      "Me gusta que una interfaz se vea bien, pero sobre todo que se entienda, cargue rápido y siga siendo mantenible cuando el producto crece.",
  },
  {
    title: "No me quedo en la capa visual",
    description:
      "He tocado APIs, despliegues, bases de datos, herramientas internas y producción. Eso me ayuda a tomar mejores decisiones también en frontend.",
  },
  {
    title: "IA, pero sin humo",
    description:
      "Quiero enseñar más trabajo de automatización e IA, pero prefiero subir cosas útiles y reales antes que llenar el portfolio de demos vacías.",
  },
];

const EXPERIENCES = [
  {
    logo: "/images/acb-dark.jpg",
    company: "ACB",
    job: "Senior Frontend Engineer",
    date: "Mayo 2024 · Actualidad",
    description:
      "Implementación de un nuevo design system, evolución de productos existentes y desarrollo de experiencias con mejor usabilidad, rendimiento y mantenibilidad.",
    technologies: [
      TECHNOLOGIES.next,
      TECHNOLOGIES.react,
      TECHNOLOGIES.astro,
      TECHNOLOGIES.node,
      TECHNOLOGIES.tailwind,
