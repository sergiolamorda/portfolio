    job: "Diseño y desarrollo de producto SaaS",
    date: "Enero 2022 · Mayo 2024",
    description:
      "Definición de casos de uso, diseño de pantallas, desarrollo full stack, despliegue en producción, gestión de base de datos y evolución del posicionamiento SEO del producto.",
    technologies: [
      TECHNOLOGIES.vue,
      TECHNOLOGIES.next,
      TECHNOLOGIES.node,
      TECHNOLOGIES.express,
      TECHNOLOGIES.mongo,
