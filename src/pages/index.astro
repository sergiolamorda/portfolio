      TECHNOLOGIES.astro,
      TECHNOLOGIES.tailwind,
      TECHNOLOGIES.svelte,
      TECHNOLOGIES.aws,
      TECHNOLOGIES.redis,
      TECHNOLOGIES.stripe,
      TECHNOLOGIES.docker,
    ],
  },
  {
    logo: "/images/acrelianews-iso.webp",
    company: "Acrelia News",
    job: "Desarrollador Full Stack",
    date: "Febrero 2019 · Diciembre 2022",
    description:
      "Análisis, diseño e implementación de nuevas funcionalidades para email marketing, SMS marketing, verificación de listas y automatizaciones orientadas a producto final.",
    technologies: [
      TECHNOLOGIES.php,
      TECHNOLOGIES.laravel,
      TECHNOLOGIES.mysql,
      TECHNOLOGIES.docker,
      TECHNOLOGIES.redis,
    ],
  },
  {
    id: "firstjob",
    logo: "/images/telera-iso.webp",
    company: "Teleradiología Avanzada",
    job: "Desarrollador Full Stack",
    date: "Junio 2018 · Febrero 2019",
    description:
      "Desarrollo de nuevas funcionalidades, soporte de aplicación de teleradiología e implementación de un gestor para la subida de pruebas médicas desde navegador.",
    technologies: [TECHNOLOGIES.php, TECHNOLOGIES.codeigniter, TECHNOLOGIES.mysql],
  },
];

const WEBS = [
  {
    title: "Pickly",
    subtitle: "Portal editorial sobre pickleball en España",
    image: "/images/webs/pickly.webp",
    url: "https://pickly.es",
    label: "Editorial sport",
  },
  {
    title: "Feri Island",
    subtitle: "Web promocional para DJ y productor musical",
    image: "/images/webs/ferisland.webp",
    url: "https://ferisland.com",
    label: "Brand site",
  },
  {
    title: "Driuz",
    subtitle: "Web de producto para SaaS e infoproducto",
    image: "/images/webs/driuz.webp",
    url: "https://driuz-web.pages.dev",
    label: "SaaS marketing",
  },
  {
    title: "Activats",
    subtitle: "Landing enfocada en conversión para gimnasio",
    image: "/images/webs/gimnasio.webp",
    url: "https://activats-web.pages.dev",
    label: "Landing page",
  },
  {
    title: "Militar Shop",
    subtitle: "Ecommerce de afiliación con catálogo y blog",
    image: "/images/webs/militar.webp",
    url: "http://militar.shop",
    label: "Ecommerce",
  },
];

const PROJECTS = [
  {
    title: "Driuz",
    type: "SaaS · producto propio",
    summary:
      "El proyecto personal más importante de mi carrera. Más de dos años construyendo un SaaS completo para creadores y profesores, desde la definición de casos de uso hasta la salida a producción.",
    highlights: [
      "Panel de administración donde los usuarios crean su web, productos digitales y operaciones de venta.",
      "Frontend y web pública trabajados con Vue, Next y una capa de diseño orientada a producto.",
      "Backend con Node.js, datos en MongoDB, despliegues en AWS, pagos con Stripe y múltiples capas de tooling alrededor del producto.",
    ],
    images: [
      { url: "/images/projects-driuz.webp", alt: "Vista principal de Driuz" },
      { url: "/images/projects-driuz-2.webp", alt: "Pantalla interna de Driuz" },
      { url: "/images/projects-driuz-3.webp", alt: "Panel de producto de Driuz" },
      { url: "/images/projects-driuz-4.webp", alt: "Pantalla de configuración en Driuz" },
      { url: "/images/projects-driuz-5.webp", alt: "Vista adicional de Driuz" },
    ],
    links: {
      web: "https://driuz-web.pages.dev",
      github: null,
    },
    technologies: [
      TECHNOLOGIES.vue,
      TECHNOLOGIES.next,
      TECHNOLOGIES.node,
      TECHNOLOGIES.express,
      TECHNOLOGIES.mongo,
      TECHNOLOGIES.react,
      TECHNOLOGIES.astro,
      TECHNOLOGIES.tailwind,
      TECHNOLOGIES.svelte,
      TECHNOLOGIES.aws,
      TECHNOLOGIES.redis,
      TECHNOLOGIES.stripe,
      TECHNOLOGIES.docker,
    ],
  },
  {
    title: "Militar Shop",
    type: "Afiliación · Laravel",
    summary:
      "Proyecto personal de afiliación construido con Laravel, panel de administración propio y una capa de automatización para actualizar catálogo, precios e imágenes.",
    highlights: [
      "Panel visual para gestionar productos, categorías y artículos del blog.",
      "Scripts de scraping para mantener actualizados precios y recursos del catálogo.",
      "Arquitectura orientada a negocio, SEO y monetización sostenida vía contenidos y afiliación.",
    ],
    images: [
      { url: "/images/militarshop-1.webp", alt: "Vista principal de Militar Shop" },
      { url: "/images/militarshop-2.webp", alt: "Listado de productos en Militar Shop" },
      { url: "/images/militarshop-3.webp", alt: "Detalle visual de Militar Shop" },
      { url: "/images/militarshop-4.webp", alt: "Sección adicional de Militar Shop" },
      { url: "/images/militarshop-5.webp", alt: "Pantalla de Militar Shop" },
    ],
    links: {
      web: "http://militar.shop",
      github: null,
    },
    technologies: [
      TECHNOLOGIES.php,
      TECHNOLOGIES.laravel,
      TECHNOLOGIES.mysql,
      TECHNOLOGIES.aws,
    ],
  },
  {
    title: "PinWall",
    type: "Experimento técnico · tiempo real",
    summary:
      "Trabajo final del grado superior: un pinball 3D multijugador construido en 30 días, con físicas en servidor, ranking y pipeline para crear escenarios nuevos con rapidez.",
    highlights: [
      "Cliente renderizado con Three.js y servidor en Node.js + Sockets.io.",
      "Modo multijugador con físicas ejecutándose en backend para mantener la sincronización.",
      "Conversión de geometrías desde SketchUp para crear escenarios reutilizables y acelerar iteración.",
    ],
    images: [
      { url: "/images/pinwall-1.webp", alt: "Vista principal de PinWall" },
      { url: "/images/pinwall-2.webp", alt: "Gameplay de PinWall" },
      { url: "/images/pinwall-3.webp", alt: "Escenario de PinWall" },
      { url: "/images/pinwall-4.webp", alt: "Multijugador de PinWall" },
      { url: "/images/pinwall-5.webp", alt: "Pantalla extra de PinWall" },
    ],
    links: {
      web: null,
      github: "https://github.com/sergiolamorda/PinWall",
    },
    technologies: [
      TECHNOLOGIES.node,
      TECHNOLOGIES.express,
      TECHNOLOGIES.mongo,
      TECHNOLOGIES.three,
      TECHNOLOGIES.sockets,
    ],
  },
];

const PROFILE_TECH = [
  TECHNOLOGIES.react,
  TECHNOLOGIES.next,
  TECHNOLOGIES.vue,
  TECHNOLOGIES.node,
  TECHNOLOGIES.astro,
  TECHNOLOGIES.tailwind,
  TECHNOLOGIES.aws,
  TECHNOLOGIES.mongo,
];

const CURRENTLY = [
  "Estoy preparando proyectos nuevos con automatización e IA, pero quiero que sean piezas reales y no ejercicios de escaparate.",
  "Me atraen roles donde producto, frontend y tooling interno se mezclen con uso práctico de IA.",
  "Sigo valorando lo mismo de siempre: rendimiento, claridad, código mantenible y criterio visual.",
];
---

<BaseLayout
  title="Sergio Lamorda | Software Engineer"
  description="Portfolio de Sergio Lamorda, software engineer con foco en frontend de alto nivel, producto digital y una evolución clara hacia automatización e IA aplicada."
>
  <section id="home" class="container-shell grid gap-8 pb-14 pt-14 lg:grid-cols-[1.15fr_0.85fr] lg:items-center lg:pb-24 lg:pt-20">
    <div class="reveal flex flex-col gap-6">
      <span class="section-kicker">Barcelona · software engineer · producto digital</span>

      <div class="space-y-5">
        <p class="note-block max-w-2xl text-base leading-7">
          No quiero que este portfolio parezca una colección de piezas generadas en serie. Prefiero enseñar trabajo real, cómo pienso y qué tipo de problemas me interesa resolver ahora.
        </p>
        <h1 class="max-w-4xl text-5xl sm:text-6xl lg:text-7xl">
          Soy Sergio. Diseño y desarrollo producto digital, sobre todo frontend, y ahora estoy abriendo más espacio a automatización e IA útil.
        </h1>
        <p class="max-w-2xl text-lg leading-8 text-[var(--muted)] sm:text-xl">
          Llevo más de 7 años trabajando en software. He pasado por producto deportivo, SaaS, email marketing, salud y proyectos propios. La parte que más se ve es el frontend, pero normalmente trabajo mejor cuando también entiendo el resto del sistema.
        </p>
      </div>

      <div class="flex flex-col gap-3 sm:flex-row">
        <Button href="#projects">Ver proyectos</Button>
        <Button href="#contact" variant="secondary">Contactar</Button>
      </div>

      <div class="flex flex-wrap gap-3">
        {
          HERO_TAGS.map((tag) => (
            <span class="tag">{tag}</span>
          ))
        }
      </div>
    </div>

    <div class="reveal" style="animation-delay: 120ms;">
      <article class="surface relative overflow-hidden p-5 sm:p-6">
        <div class="relative flex flex-col gap-6">
          <div class="flex items-start justify-between gap-4">
            <div class="space-y-2">
              <p class="text-sm font-semibold uppercase tracking-[0.16em] text-[var(--accent-strong)]">Perfil</p>
              <h2 class="text-2xl sm:text-3xl">Frontend fuerte, pero no solo frontend</h2>
            </div>
            <img
              class="size-20 rounded-[26px] border border-[var(--line)] object-cover shadow-lg"
              src="/images/sergio-lamorda.webp"
              alt="Retrato de Sergio Lamorda"
            />
          </div>

          <div class="grid grid-cols-2 gap-3">
            {
              METRICS.map(({ value, label }) => (
                <div class="surface-strong p-4">
                  <p class="text-2xl font-bold text-[var(--text)] sm:text-3xl">{value}</p>
                  <p class="mt-2 text-sm leading-6 text-[var(--muted)]">{label}</p>
                </div>
              ))
            }
          </div>

          <div class="space-y-3">
            <p class="text-sm font-semibold uppercase tracking-[0.16em] text-[var(--accent-strong)]">Stack habitual</p>
            <div class="flex flex-wrap gap-2">
              {
                PROFILE_TECH.map((technology) => (
                  <span class="tag">
                    <technology.icon class="size-4" />
                    {technology.name}
                  </span>
                ))
              }
            </div>
          </div>

          <p class="note-block text-sm leading-7 sm:text-base">
            Mi siguiente paso no es “hacer una web de IA”. Es enseñar mejor el tipo de ingeniería que me interesa: automatización, tooling y producto con criterio.
          </p>
        </div>
      </article>
    </div>
  </section>

  <section class="container-shell pb-8 lg:pb-16">
    <div class="reveal flex flex-col gap-8">
      <div class="flex flex-col gap-4 lg:flex-row lg:items-end lg:justify-between">
        <div class="space-y-4">
          <span class="section-kicker">Lo que mejor se me da</span>
          <h2 class="max-w-2xl text-4xl sm:text-5xl">No me gusta separar diseño, frontend y producto como si no se tocaran.</h2>
        </div>
        <p class="max-w-xl text-base leading-7 text-[var(--muted)] sm:text-lg">
          Mi valor suele estar en el cruce: una interfaz que tenga sentido, una implementación limpia y una visión bastante realista de cómo eso afecta al producto y al negocio.
        </p>
      </div>

      <div class="grid gap-4 lg:grid-cols-3">
        {
          FOCUS_AREAS.map((area, index) => (
            <article class="surface reveal p-6 sm:p-7" style={`animation-delay: ${120 + index * 80}ms;`}>
              <div class="space-y-4">
                <p class="text-xs font-semibold uppercase tracking-[0.18em] text-[var(--muted)]">0{index + 1}</p>
                <h3 class="text-2xl sm:text-[2rem]">{area.title}</h3>
                <p class="text-base leading-7 text-[var(--muted)]">{area.description}</p>
              </div>
            </article>
          ))
        }
      </div>
    </div>
  </section>

  <section id="experience" class="container-shell py-16 lg:py-24">
    <div class="reveal flex flex-col gap-4 lg:flex-row lg:items-end lg:justify-between">
      <div class="space-y-4">
        <span class="section-kicker">Experiencia</span>
        <h2 class="max-w-2xl text-4xl sm:text-5xl">Sitios distintos, mismo patrón: producto real y trabajo en producción.</h2>
      </div>
      <p class="max-w-xl text-base leading-7 text-[var(--muted)] sm:text-lg">
        He pasado por SaaS, marketing automation, salud y producto deportivo. Me interesa enseñar esta parte porque explica mejor mi perfil que cualquier lista de tecnologías.
      </p>
    </div>

    <div class="mt-10 grid gap-5">
      {
        EXPERIENCES.map(({ id, logo, company, job, date, description, technologies }, index) => (
          <article id={id} class="surface reveal grid gap-5 p-6 lg:grid-cols-[auto_1fr_auto] lg:items-start lg:p-7" style={`animation-delay: ${80 + index * 70}ms;`}>
            <div class="flex h-14 w-14 items-center justify-center rounded-2xl border border-[var(--line)] bg-white/80 p-3 shadow-sm">
              <img src={logo} alt={`Logo de ${company}`} class="max-h-8 w-auto" />
            </div>

            <div class="space-y-4">
              <div class="space-y-2">
                <p class="text-sm font-semibold uppercase tracking-[0.16em] text-[var(--accent-strong)]">{company}</p>
                <h3 class="text-2xl sm:text-[2rem]">{job}</h3>
                <p class="max-w-3xl text-base leading-7 text-[var(--muted)]">{description}</p>
              </div>

              <div class="flex flex-wrap gap-2">
                {
                  technologies.map((technology) => (
                    <span class="tag">
                      <technology.icon class="size-4" />
                      {technology.name}
                    </span>
                  ))
                }
              </div>
            </div>

            <p class="text-sm font-medium text-[var(--muted)] lg:pt-1 lg:text-right">{date}</p>
          </article>
        ))
      }
    </div>
  </section>

  <section id="webs" class="container-shell py-16 lg:py-24">
    <div class="reveal flex flex-col gap-4 lg:flex-row lg:items-end lg:justify-between">
      <div class="space-y-4">
        <span class="section-kicker">Webs y landings</span>
        <h2 class="max-w-2xl text-4xl sm:text-5xl">También me gusta cuando una web tiene que vender algo y no solo verse bonita.</h2>
      </div>
      <p class="max-w-xl text-base leading-7 text-[var(--muted)] sm:text-lg">
        Aquí hay piezas más orientadas a comunicación, branding y conversión. Me interesa mantenerlas porque muestran una parte del criterio visual que luego también aplico en producto.
      </p>
    </div>

    <div class="mt-10 grid gap-5 md:grid-cols-2">
      {
        WEBS.map((web, index) => (
          <a href={web.url} target="_blank" rel="noreferrer" class="group reveal" style={`animation-delay: ${100 + index * 70}ms;`}>
            <article class="surface overflow-hidden p-4 sm:p-5">
              <div class="media-frame aspect-[16/10] overflow-hidden">
                <img
                  src={web.image}
                  alt={web.title}
                  class="h-full w-full object-cover transition duration-500 group-hover:scale-[1.03]"
                />
              </div>
              <div class="flex flex-col gap-3 px-1 pb-1 pt-5">
                <div class="flex items-center justify-between gap-4">
                  <p class="text-xs font-semibold uppercase tracking-[0.18em] text-[var(--muted)]">{web.label}</p>
                  <WorldIcon class="size-6 text-[var(--accent-strong)] transition duration-300 group-hover:translate-x-1 group-hover:-translate-y-1" />
                </div>
                <div class="space-y-2">
                  <h3 class="text-2xl">{web.title}</h3>
                  <p class="text-base leading-7 text-[var(--muted)]">{web.subtitle}</p>
                </div>
              </div>
            </article>
          </a>
        ))
      }
    </div>
  </section>

  <section id="projects" class="container-shell py-16 lg:py-24">
    <div class="reveal flex flex-col gap-4 lg:flex-row lg:items-end lg:justify-between">
      <div class="space-y-4">
        <span class="section-kicker">Proyectos seleccionados</span>
        <h2 class="max-w-2xl text-4xl sm:text-5xl">Estos proyectos explican bastante mejor cómo trabajo que un CV.</h2>
      </div>
      <p class="max-w-xl text-base leading-7 text-[var(--muted)] sm:text-lg">
        He dejado proyectos distintos a propósito: un SaaS propio, una web de afiliación con automatización detrás y un proyecto técnico de tiempo real. Lo siguiente que vaya entrando estará más cerca de IA y tooling.
      </p>
    </div>

    <div class="mt-10 flex flex-col gap-8">
      {
        PROJECTS.map((project, index) => (
          <article class="surface reveal overflow-hidden p-5 sm:p-6 lg:p-7" style={`animation-delay: ${100 + index * 80}ms;`}>
            <div class="grid gap-8 lg:grid-cols-[0.95fr_1.05fr] lg:items-start">
              <div class="flex flex-col gap-5">
                <div class="flex flex-wrap items-start justify-between gap-4">
                  <div class="space-y-3">
                    <p class="text-xs font-semibold uppercase tracking-[0.18em] text-[var(--muted)]">{project.type}</p>
                    <h3 class="text-3xl sm:text-4xl">{project.title}</h3>
                  </div>

                  <div class="flex items-center gap-2">
                    {
                      project.links.web && (
                        <Button href={project.links.web} target="_blank" rel="noreferrer" variant="secondary" class="!px-4 !py-2.5">
                          <WorldIcon class="size-4" />
                          Ver web
                        </Button>
                      )
                    }
                    {
                      project.links.github && (
                        <Button href={project.links.github} target="_blank" rel="noreferrer" variant="secondary" class="!px-4 !py-2.5">
                          <GithubIcon class="size-4" />
                          GitHub
                        </Button>
                      )
                    }
                  </div>
                </div>

                <p class="text-base leading-7 text-[var(--muted)] sm:text-lg">{project.summary}</p>

                <ul class="grid gap-3">
                  {
                    project.highlights.map((highlight) => (
                      <li class="flex gap-3">
                        <span class="mt-2 h-2.5 w-2.5 rounded-full bg-[var(--accent)]"></span>
                        <span class="text-sm leading-7 text-[var(--muted-strong)] sm:text-base">{highlight}</span>
                      </li>
                    ))
                  }
                </ul>

                <div class="flex flex-wrap gap-2 pt-1">
                  {
                    project.technologies.map((technology) => (
                      <span class="tag">
                        <technology.icon class="size-4" />
                        {technology.name}
                      </span>
                    ))
                  }
                </div>
              </div>

